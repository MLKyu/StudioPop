<?xml version="1.0" encoding="utf-8"?>
<!--
  StudioPop launcher foreground.
  Adaptive icon viewport: 108×108. 안전영역(원형 마스크 통과 보장) ≈ 중앙 72×72 (18..90).

  컨셉: 채널 'ShuPick Crane' 의 크레인 클로가 영상 편집기의 ▶ 플레이 버튼을
  잡고 있는 모습. 네온 그린(브랜드) + 흰색 플레이.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 1. 크레인 상단 마운트 (네온 그린 박스) -->
    <path
        android:fillColor="#A6FF00"
        android:pathData="M48,18 L60,18 L60,28 L48,28 Z" />

    <!-- 2. 마운트 위 LED 점등 (흰색 작은 사각) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M53.5,20.5 L56.5,20.5 L56.5,23.5 L53.5,23.5 Z" />

    <!-- 3. 크레인 와이어/스템 (얇은 세로 막대) -->
    <path
        android:fillColor="#A6FF00"
        android:pathData="M53,28 L55,28 L55,36 L53,36 Z" />

    <!-- 4. 클로 마운트 가로 바 -->
    <path
        android:fillColor="#A6FF00"
        android:pathData="M38,36 L70,36 L70,42 L38,42 Z" />

    <!-- 5. 왼쪽 클로 암 (위는 안쪽 / 아래는 바깥쪽으로 벌어졌다 끝에서 안으로) -->
    <path
        android:fillColor="#A6FF00"
        android:pathData="M38,42 L48,42 L42,72 L34,80 L30,76 Z" />

    <!-- 6. 오른쪽 클로 암 (좌우 대칭) -->
    <path
        android:fillColor="#A6FF00"
        android:pathData="M70,42 L60,42 L66,72 L74,80 L78,76 Z" />

    <!-- 7. 클로 끝 (안쪽으로 살짝 굽힘 — 그립 강조) -->
    <path
        android:fillColor="#A6FF00"
        android:pathData="M34,80 L46,76 L42,82 Z" />
    <path
        android:fillColor="#A6FF00"
        android:pathData="M74,80 L62,76 L66,82 Z" />

    <!-- 8. 잡혀 있는 흰색 플레이 트라이앵글 ▶ (영상 편집 정체성) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M44,52 L66,64 L44,76 Z" />
</vector>
