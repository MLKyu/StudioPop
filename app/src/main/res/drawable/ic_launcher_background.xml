<?xml version="1.0" encoding="utf-8"?>
<!-- StudioPop launcher background — solid dark with subtle radial highlight -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base dark fill -->
    <path
        android:fillColor="#0D1117"
        android:pathData="M0,0h108v108h-108z" />

    <!-- Subtle radial brand glow (neon green) centered -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="60"
                android:type="radial">
                <item android:offset="0.0" android:color="#33A6FF00" />
                <item android:offset="0.5" android:color="#11A6FF00" />
                <item android:offset="1.0" android:color="#000D1117" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
